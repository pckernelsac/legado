# ============================================================================
# LEGADO ETERNO — Variables de entorno
# Copia este archivo a `.env` y sustituye TODOS los secretos en producción.
# ============================================================================

# --- General ----------------------------------------------------------------
ENVIRONMENT=development            # development | staging | production
PROJECT_NAME=Legado Eterno
DOMAIN=legadoeterno.com
PUBLIC_BASE_URL=https://legadoeterno.com
API_BASE_URL=https://legadoeterno.com/api
TZ=America/Lima

# --- Backend / FastAPI -------------------------------------------------------
SECRET_KEY=change-me-to-a-64-char-random-hex-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=legadoeterno
JWT_AUDIENCE=legadoeterno-app
BACKEND_CORS_ORIGINS=http://localhost:5173,https://legadoeterno.com
LOG_LEVEL=INFO
WORKERS=4

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=legadoeterno
POSTGRES_USER=legado
POSTGRES_PASSWORD=change-me-strong-db-password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_DB=0
CELERY_BROKER_DB=1
CELERY_RESULT_DB=2

# --- MinIO (S3) --------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=https://cdn.legadoeterno.com
MINIO_ROOT_USER=legado-minio-admin
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_BUCKET_MEDIA=memorial-media
MINIO_BUCKET_QR=qr-codes
MINIO_SECURE=false
MINIO_REGION=us-east-1

# --- Email (verificación / recuperación) ------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@legadoeterno.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=no-reply@legadoeterno.com
SMTP_FROM_NAME=Legado Eterno
SMTP_TLS=true

# --- Seguridad ---------------------------------------------------------------
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=120/minute
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
CSRF_SECRET=change-me-csrf-secret

# --- Pagos (placeholders, integración futura) -------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=

# --- IA (placeholders, integración futura) ----------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Frontend ----------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api
VITE_PUBLIC_BASE_URL=http://localhost:5173
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
