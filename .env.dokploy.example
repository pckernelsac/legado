# ============================================================================
# LEGADO ETERNO — Variables para despliegue en DOKPLOY
# ----------------------------------------------------------------------------
# Pega TODO este bloque en la pestaña "Environment" del servicio Compose en
# Dokploy. Reemplaza los valores marcados con  <<< CAMBIAR >>>.
#
# Este archivo es una PLANTILLA pública (se versiona en Git): NO contiene
# secretos reales. Genera cada secreto con:  openssl rand -hex 32
# ============================================================================

# --- General ----------------------------------------------------------------
ENVIRONMENT=production
PROJECT_NAME=Legado Eterno

# <<< CAMBIAR >>> dominio que asignes en Dokploy (sin barra final).
# Mientras no tengas dominio propio, usa el que genera Dokploy (p.ej. *.traefik.me).
DOMAIN=legado.tudominio.com
PUBLIC_BASE_URL=https://legado.tudominio.com
API_BASE_URL=https://legado.tudominio.com/api
TZ=America/Lima

# --- Backend / FastAPI -------------------------------------------------------
SECRET_KEY=<<< CAMBIAR: openssl rand -hex 32 >>>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=legadoeterno
JWT_AUDIENCE=legadoeterno-app
# Debe incluir el dominio público (mismo que PUBLIC_BASE_URL).
BACKEND_CORS_ORIGINS=https://legado.tudominio.com
LOG_LEVEL=INFO
WORKERS=4

# --- PostgreSQL (BD GESTIONADA de Dokploy) ----------------------------------
POSTGRES_HOST=app-legado-db-8h5dty
POSTGRES_PORT=5432
POSTGRES_DB=legado
POSTGRES_USER=legado_user
POSTGRES_PASSWORD=<<< CAMBIAR: contraseña de tu BD gestionada en Dokploy >>>
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis (auto-alojado en el compose) -------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<<< CAMBIAR: openssl rand -hex 24 >>>
REDIS_DB=0
CELERY_BROKER_DB=1
CELERY_RESULT_DB=2

# --- MinIO (S3, auto-alojado en el compose) ---------------------------------
# Endpoint INTERNO (server-a-server, red Docker): siempre HTTP, sin TLS.
MINIO_ENDPOINT=legado-minio:9000
# Endpoint PÚBLICO usado para firmar las presigned URLs (subida/descarga desde
# el navegador). Con el ruteo de buckets en nginx (legado-proxy reenvía
# /memorial-media/ y /qr-codes/ a legado-minio:9000), apunta al DOMINIO PRINCIPAL
# de la app. Alternativa: un subdominio dedicado a MinIO (puerto 9000) en Dokploy.
# <<< CAMBIAR >>> por tu dominio:
MINIO_PUBLIC_ENDPOINT=https://legado.tudominio.com
MINIO_ROOT_USER=legado-minio-admin
MINIO_ROOT_PASSWORD=<<< CAMBIAR: openssl rand -hex 20 >>>
MINIO_BUCKET_MEDIA=memorial-media
MINIO_BUCKET_QR=qr-codes
# IMPORTANTE: false. Solo afecta al cliente INTERNO (MINIO_ENDPOINT), que habla
# HTTP. El endpoint público ya fuerza HTTPS por llevar el esquema explícito.
# Ponerlo en true hace que el backend intente https://legado-minio:9000 y rompe
# las operaciones server-a-server (p. ej. confirm de subida -> 422).
MINIO_SECURE=false
MINIO_REGION=us-east-1

# --- Email (verificación / recuperación) ------------------------------------
# <<< CAMBIAR >>> credenciales SMTP reales (sin esto no salen emails).
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@legadoeterno.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=no-reply@legadoeterno.com
SMTP_FROM_NAME=Legado Eterno
SMTP_TLS=true

# --- Seguridad ---------------------------------------------------------------
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=120/minute
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
CSRF_SECRET=<<< CAMBIAR: openssl rand -hex 16 >>>

# --- Pagos / IA (placeholders, integración futura) --------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Frontend (se inyectan como build args del contenedor frontend) ---------
VITE_API_BASE_URL=https://legado.tudominio.com/api
VITE_PUBLIC_BASE_URL=https://legado.tudominio.com
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
